{
  "expo": {
    "name": "Welcome",
    "slug": "Welcome",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/HostelLogo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/HostelLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4FBF8",
      "imageWidth": 300
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/HostelLogo.png",
        "backgroundColor": "#F4FBF8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Welcome",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MANAGE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/HostelLogo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/HostelLogo.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#F4FBF8"
        }
      ],
      [
        "expo-file-system",
        {
          "photosPermission": "Allow access to save PDF reports."
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}